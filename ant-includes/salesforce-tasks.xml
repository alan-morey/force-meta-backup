<?xml version="1.0" encoding="UTF-8"?>
<project name="salesforce.tasks" basedir="." xmlns:sf="antlib:com.salesforce" xmlns:if="ant:if" xmlns:unless="ant:unless">
  <!--
    Tasks that wrap Ant Migraton Tool tasks

    https://developer.salesforce.com/docs/atlas.en-us.daas.meta/daas/meta_development.htm
  -->

  <!-- The version of the antlib jar in lib. There are no more releases after v59 -->
  <property name="salesforce.antlib.version" value="59.0" />

  <taskdef
    uri="antlib:com.salesforce"
    resource="com/salesforce/antlib.xml"
    classpath="lib/ant-salesforce-${salesforce.antlib.version}.jar"
    onerror="failall"
  />

  <macrodef name="sfRetrieveToFolder" description="Retreive metadata from Salesforce into specified folder">
    <attribute name="unpackaged" description="The path of the manifest file that specifies the components to be retrieved"/>
    <attribute name="retrieveTarget" description="The path of the folder into which the metadata files are retreived, this folder will be created"/>

    <sequential>
      <mkdir dir="@{retrieveTarget}" />

      <sfRetrieve unpackaged="@{unpackaged}" retrieveTarget="@{retrieveTarget}" />
    </sequential>

  </macrodef>

  <presetdef name="sfRetrieve" description="Retreive metadata from Salesforce into specified folder">
    <sf:retrieve
      sessionId="${sf.sessionId}"
      serverurl="${sf.serverurl}"
      retrieveTarget="${build.metadata.dir}"
      pollWaitMillis="${sf.pollWaitMillis}"
      maxPoll="${sf.maxPoll}"
      apiVersion="${sf.apiVersion}"
    />
  </presetdef>

  <macrodef name="sfBulkRetrieve" description="Bulk retrieve metadata from Salesforce">
    <attribute name="metadataType" />
    <attribute name="containingFolder" default="" />

    <attribute name="sessionId"        default="${sf.sessionId}" />
    <attribute name="serverurl"        default="${sf.serverurl}" />
    <attribute name="retrieveTarget"   default="${build.metadata.dir}" />
    <attribute name="pollWaitMillis"   default="${sf.pollWaitMillis}" />
    <attribute name="maxPoll"          default="${sf.maxPoll}" />
    <attribute name="apiVersion"       default="${sf.apiVersion}" />
    <attribute name="batchSize"        default="${sf.batchSize}" />

    <sequential>
      <local name="has.folder" />
      <local name="local.batchSize" />

      <condition property="has.folder">
        <not><equals arg1="@{containingFolder}" arg2="" /></not>
      </condition>

      <condition property="local.batchSize" value="${sf.batchSize.@{metadataType}}">
        <isset property="sf.batchSize.@{metadataType}" />
      </condition>

      <condition property="local.batchSize" value="@{batchSize}">
        <not><isset property="local.batchSize" /></not>
      </condition>

      <presetdef name="sfBulkRetrievePreset">
        <sf:bulkRetrieve
          metadataType="@{metadataType}"
          sessionId="@{sessionId}"
          serverurl="@{serverurl}"
          retrieveTarget="@{retrieveTarget}"
          pollWaitMillis="@{pollWaitMillis}"
          maxPoll="@{maxPoll}"
          batchSize="${local.batchSize}"
          apiVersion="@{apiVersion}"
        />
      </presetdef>

      <sfBulkRetrievePreset if:set="has.folder" containingFolder="@{containingFolder}" />
      <sfBulkRetrievePreset unless:set="has.folder" />

    </sequential>
  </macrodef>
</project>
